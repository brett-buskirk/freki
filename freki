#!/usr/bin/env bash
# freki — the estate's reaper. Finds and clears GitHub cruft across $FREKI_ROOT (default ~/github-repos).
# Odin's wolf: the one with teeth. Dry-run by default — nothing is deleted without --apply.
#
#   freki branches | prs | artifacts | releases | reap
#   run 'freki help' for the menu, or 'freki <command> help' for per-command detail.
set -uo pipefail
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; HERE="$(cd "$(dirname "$SELF")" && pwd)"
# ── configuration — env  >  config file  >  smart defaults ────────────────
CONFIG="${FREKI_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/freki/config}"
for _v in ROOT OWNER STALE_DAYS PR_STALE_DAYS CONVENTIONS; do eval "_env_$_v=\${FREKI_$_v-}"; done
[ -f "$CONFIG" ] && . "$CONFIG"

# free config for huginn users — if FREKI_* is unset, fall back to huginn's config
HCONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/huginn/config"
[ -f "$HCONFIG" ] && . "$HCONFIG"

ROOT="${_env_ROOT:-${FREKI_ROOT:-${HUGINN_ROOT:-$HOME/github-repos}}}"
OWNER="${_env_OWNER:-${FREKI_OWNER:-${HUGINN_OWNER:-}}}"                 # resolved lazily — see need_owner
STALE_DAYS="${_env_STALE_DAYS:-${FREKI_STALE_DAYS:-90}}"                 # branches: days since last commit to count as stale
PR_STALE_DAYS="${_env_PR_STALE_DAYS:-${FREKI_PR_STALE_DAYS:-180}}"       # prs: days with no activity to count as abandoned
FAMILY="${HUGINN_FAMILY:-}"                                              # space-separated repos to exclude — shared with huginn
CONV="$ROOT/${_env_CONVENTIONS:-${FREKI_CONVENTIONS:-${HUGINN_CONVENTIONS:-repo-conventions}}}"

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; C=$'\e[36m'; M=$'\e[35m'; DIM=$'\e[2m'; BD=$'\e[1m'; X=$'\e[0m'
else R=; G=; Y=; C=; M=; DIM=; BD=; X=; fi

is_exempt(){ case " $FAMILY $CONV_EXEMPT " in *" $1 "*) return 0;; *) return 1;; esac; }  # HUGINN_FAMILY env + conventions exemptions.json
is_help(){ case "${1:-}" in help|-h|--help) return 0;; *) return 1;; esac; }
repos(){ (cd "$ROOT" && for d in */; do [ -d "${d}.git" ] && echo "${d%/}"; done | sort); }
need_owner(){ [ -n "$OWNER" ] && return 0; OWNER="$(gh api user --jq .login 2>/dev/null)"; [ -n "$OWNER" ] && return 0; printf "  ${R}no GitHub owner set.${X} Set FREKI_OWNER (or HUGINN_OWNER), or add it to %s.\n" "$CONFIG" >&2; return 1; }
first_of(){ local f; for f in "$@"; do [ -e "$f" ] && { printf '%s' "$f"; return 0; }; done; return 1; }  # your conventions repo, else bundled templates
human_size(){ local b="$1"; if [ "$b" -ge 1073741824 ]; then printf '%dGB' $((b/1073741824)); elif [ "$b" -ge 1048576 ]; then printf '%dMB' $((b/1048576)); else printf '%dKB' $((b/1024)); fi; }
need_deps(){ local d; local -a miss=(); for d in git gh jq; do command -v "$d" >/dev/null 2>&1 || miss+=("$d"); done; [ ${#miss[@]} -eq 0 ] && return 0; printf "  ${R}missing required tool(s): %s${X} ${DIM}(freki needs bash, git, gh, jq)${X}\n" "${miss[*]}" >&2; return 1; }

# exempt repos from the conventions data (merged with HUGINN_FAMILY by is_exempt)
CONV_EXEMPT=""
if command -v jq >/dev/null 2>&1; then
  _ej="$(first_of "$CONV/exemptions.json" "$HERE/templates/exemptions.json")"
  [ -n "$_ej" ] && CONV_EXEMPT="$(jq -r '.exempt[].repo' "$_ej" 2>/dev/null | tr '\n' ' ')"
else
  printf "  ${Y}jq not found — exemptions.json won't be honored this run, only \$HUGINN_FAMILY.${X}\n" >&2
fi

# ── safety spine — dry-run / --apply / confirm ────────────────────────────
# Every command that deletes something routes through here. Dry-run is the
# default: would() reports, do_it() only mutates when the command's own
# `--apply` flag set APPLY=1. Confirms interactively unless `--yes` set YES=1.
APPLY=0; YES=0
LOGFILE="${XDG_STATE_HOME:-$HOME/.local/state}/freki/reaped.log"

would(){ printf "  ${DIM}[dry-run] would %s${X}\n" "$1"; }  # $1 = description of the action

confirm(){  # $1 = prompt; 0 = go, 1 = abort. Reads /dev/tty so piped stdin can't silently skip it.
  [ "$YES" = 1 ] && return 0
  if [ ! -r /dev/tty ]; then printf "  ${Y}no tty for confirmation — pass --yes to proceed non-interactively.${X}\n" >&2; return 1; fi
  local reply; printf "  ${Y}%s${X} ${DIM}[y/N]${X} " "$1" > /dev/tty; read -r reply < /dev/tty
  case "$reply" in y|Y|yes|YES) return 0;; *) return 1;; esac
}

log_action(){ mkdir -p "$(dirname "$LOGFILE")"; printf '%s\t%s\t%s\t%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$1" "$2" "$3" >> "$LOGFILE"; }  # repo, kind, detail

do_it(){  # $1=repo $2=kind $3=description $4..=the actual delete command
  local repo="$1" kind="$2" desc="$3"; shift 3
  if [ "$APPLY" != 1 ]; then would "$desc"; return 0; fi
  if ! confirm "delete $desc?"; then printf "  ${DIM}∙ skipped${X} %s\n" "$desc"; return 1; fi
  if "$@"; then printf "  ${G}✓ deleted${X} %s\n" "$desc"; log_action "$repo" "$kind" "$desc"; return 0
  else printf "  ${R}✗ failed${X} %s\n" "$desc"; return 1; fi
}

# ── branches (merged / stale — estate-wide) ───────────────────────────────
cmd_branches(){
  is_help "${1:-}" && { help_branches; return 0; }
  need_deps || return 1
  APPLY=0; YES=0; local FORCE=0
  for a in "$@"; do case "$a" in
    --apply) APPLY=1;; --yes|-y) YES=1;; --force) FORCE=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}freki branches${X}  ${DIM}· merged/stale branches, estate-wide (stale ≥ %sd)${X}\n\n" "$STALE_DAYS"

  local -a CAND=()  # repo \x1f scope \x1f ref \x1f description — scope: local|localforce|remote|remoteforce
  local now; now=$(date +%s)
  local repos_flagged=0

  while read -r d; do
    is_exempt "$d" && continue
    local GD="$ROOT/$d"
    git -C "$GD" fetch -q --prune origin >/dev/null 2>&1
    local def cur mergedset printed=0 flagged=0
    def=$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); def=${def:-main}
    cur=$(git -C "$GD" symbolic-ref --short HEAD 2>/dev/null)
    mergedset=$(git -C "$GD" for-each-ref --format='%(refname:short)' --merged "origin/$def" refs/heads refs/remotes/origin 2>/dev/null)

    while read -r b; do
      [ -z "$b" ] && continue; [ "$b" = "$def" ] && continue; [ "$b" = "$cur" ] && continue
      local ts age; ts=$(git -C "$GD" log -1 --format=%ct "$b" 2>/dev/null); age=$(( (now - ${ts:-$now}) / 86400 ))
      [ "$printed" = 0 ] && { printf "  ${BD}%s${X} ${DIM}(default: %s)${X}\n" "$d" "$def"; printed=1; }
      if grep -qx "$b" <<<"$mergedset"; then
        printf "    ${DIM}∙${X} %s ${G}(merged, %sd)${X}\n" "$b" "$age"
        CAND+=("$d"$'\x1f'"local"$'\x1f'"$b"$'\x1f'"$d local branch '$b' (merged, ${age}d)"); flagged=1
      elif [ "$age" -ge "$STALE_DAYS" ]; then
        if [ "$FORCE" = 1 ]; then
          printf "    ${DIM}∙${X} %s ${Y}(unmerged, stale %sd — force)${X}\n" "$b" "$age"
          CAND+=("$d"$'\x1f'"localforce"$'\x1f'"$b"$'\x1f'"$d local branch '$b' (UNMERGED, stale ${age}d, forced)"); flagged=1
        else printf "    ${DIM}∙${X} %s ${Y}(unmerged, stale %sd — needs --force)${X}\n" "$b" "$age"; fi
      else printf "    ${DIM}∙${X} %s ${DIM}(unmerged, active)${X}\n" "$b"; fi
    done < <(git -C "$GD" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)

    while read -r rb; do
      [ -z "$rb" ] && continue
      local b="${rb#origin/}"
      [ "$b" = "$def" ] && continue; [ "$b" = "HEAD" ] && continue
      local ts age; ts=$(git -C "$GD" log -1 --format=%ct "$rb" 2>/dev/null); age=$(( (now - ${ts:-$now}) / 86400 ))
      [ "$printed" = 0 ] && { printf "  ${BD}%s${X} ${DIM}(default: %s)${X}\n" "$d" "$def"; printed=1; }
      if grep -qx "$rb" <<<"$mergedset"; then
        printf "    ${DIM}∙${X} origin/%s ${G}(merged, %sd)${X}\n" "$b" "$age"
        CAND+=("$d"$'\x1f'"remote"$'\x1f'"$b"$'\x1f'"$d remote branch 'origin/$b' (merged, ${age}d)"); flagged=1
      elif [ "$age" -ge "$STALE_DAYS" ]; then
        if [ "$FORCE" = 1 ]; then
          printf "    ${DIM}∙${X} origin/%s ${Y}(unmerged, stale %sd — force)${X}\n" "$b" "$age"
          CAND+=("$d"$'\x1f'"remoteforce"$'\x1f'"$b"$'\x1f'"$d remote branch 'origin/$b' (UNMERGED, stale ${age}d, forced)"); flagged=1
        else printf "    ${DIM}∙${X} origin/%s ${Y}(unmerged, stale %sd — needs --force)${X}\n" "$b" "$age"; fi
      else printf "    ${DIM}∙${X} origin/%s ${DIM}(unmerged, active)${X}\n" "$b"; fi
    done < <(git -C "$GD" for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null)

    [ "$flagged" = 1 ] && repos_flagged=$((repos_flagged+1))
  done < <(repos)

  local n=${#CAND[@]}
  REAP_BR_N=$n; REAP_BR_REPOS=$repos_flagged
  if [ "$n" -eq 0 ]; then printf "  ${G}✓ no merged or stale branches anywhere${X}\n\n"; return 0; fi

  if [ "$APPLY" != 1 ]; then
    printf "\n  ${DIM}%d branch(es) across %d repo(s) · 'freki branches --apply' deletes the merged ones (add --force for stale-unmerged)${X}\n\n" "$n" "$repos_flagged"
    return 0
  fi

  printf "\n"
  if ! confirm "delete $n branch(es) across $repos_flagged repo(s)?"; then
    printf "  ${DIM}aborted — nothing deleted.${X}\n\n"; return 0
  fi
  YES=1  # confirmed as a batch — do_it's own per-item confirm becomes a no-op below

  local deleted=0 failed=0 c
  for c in "${CAND[@]}"; do
    local repo scope ref desc kind
    IFS=$'\x1f' read -r repo scope ref desc <<< "$c"
    local GD="$ROOT/$repo"
    case "$scope" in local|localforce) kind="local-branch";; *) kind="remote-branch";; esac
    case "$scope" in
      local)      do_it "$repo" "$kind" "$desc" git -C "$GD" branch -d "$ref" && deleted=$((deleted+1)) || failed=$((failed+1));;
      localforce) do_it "$repo" "$kind" "$desc" git -C "$GD" branch -D "$ref" && deleted=$((deleted+1)) || failed=$((failed+1));;
      *)          do_it "$repo" "$kind" "$desc" git -C "$GD" push origin --delete "$ref" && deleted=$((deleted+1)) || failed=$((failed+1));;
    esac
  done
  printf "\n  ${BD}%d deleted${X}%s\n\n" "$deleted" "$([ "$failed" -gt 0 ] && printf "  ${DIM}·${X} ${R}%d failed${X}" "$failed")"
}

# ── prs (abandoned open PRs) ───────────────────────────────────────────────
cmd_prs(){
  is_help "${1:-}" && { help_prs; return 0; }
  need_deps || return 1
  need_owner || return 1
  APPLY=0; YES=0
  for a in "$@"; do case "$a" in
    --apply) APPLY=1;; --yes|-y) YES=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}freki prs${X}  ${DIM}· abandoned open PRs (no activity ≥ %sd)${X}\n\n" "$PR_STALE_DAYS"

  local rows; rows=$(gh search prs --owner "$OWNER" --state open --limit 100 \
    --json repository,number,title,author,updatedAt --jq '.[] | [.repository.name,(.number|tostring),.title,.author.login,.updatedAt] | @tsv' 2>/dev/null)

  local -a CAND=()  # repo \x1f number \x1f description
  local now; now=$(date +%s)
  local n=0 stale=0

  while IFS=$'\t' read -r repo num title author updated; do
    [ -z "$repo" ] && continue
    is_exempt "$repo" && continue
    n=$((n+1))
    local ts age; ts=$(date -d "$updated" +%s 2>/dev/null); age=$(( (now - ${ts:-$now}) / 86400 ))
    if [ "$age" -ge "$PR_STALE_DAYS" ]; then
      printf "  ${C}%-24s${X} ${BD}#%-4s${X} %s ${DIM}(@%s · %sd inactive)${X}\n" "$repo" "$num" "$title" "$author" "$age"
      CAND+=("$repo"$'\x1f'"$num"$'\x1f'"$repo #$num '$title' (${age}d inactive)"); stale=$((stale+1))
    else
      printf "  ${DIM}∙ %-22s${X} ${BD}#%-4s${X} %s ${DIM}(@%s · %sd ago)${X}\n" "$repo" "$num" "$title" "$author" "$age"
    fi
  done < <(printf '%s\n' "$rows")

  REAP_PR_N=$n; REAP_PR_STALE=$stale
  if [ "$n" -eq 0 ]; then printf "  ${G}✓ nothing open${X}\n\n"; return 0; fi

  if [ "$APPLY" != 1 ]; then
    printf "\n  ${BD}%d open${X} ${DIM}·${X} ${Y}%d abandoned (≥%sd)${X} ${DIM}· 'freki prs --apply' closes the abandoned ones${X}\n\n" "$n" "$stale" "$PR_STALE_DAYS"
    return 0
  fi

  local m=${#CAND[@]}
  if [ "$m" -eq 0 ]; then printf "\n  ${G}✓ nothing abandoned to close${X}\n\n"; return 0; fi

  printf "\n"
  if ! confirm "close $m abandoned PR(s)?"; then printf "  ${DIM}aborted — nothing closed.${X}\n\n"; return 0; fi
  YES=1

  local closed=0 failed=0 c
  for c in "${CAND[@]}"; do
    local repo num desc
    IFS=$'\x1f' read -r repo num desc <<< "$c"
    do_it "$repo" "pr" "$desc" gh pr close "$num" -R "$OWNER/$repo" \
      --comment "Closing — no activity in ${PR_STALE_DAYS}+ days. Reopen anytime if this is still relevant. (via freki)" \
      && closed=$((closed+1)) || failed=$((failed+1))
  done
  printf "\n  ${BD}%d closed${X}%s\n\n" "$closed" "$([ "$failed" -gt 0 ] && printf "  ${DIM}·${X} ${R}%d failed${X}" "$failed")"
}

# ── artifacts (old CI workflow artifacts) ─────────────────────────────────
cmd_artifacts(){
  is_help "${1:-}" && { help_artifacts; return 0; }
  need_deps || return 1
  need_owner || return 1
  APPLY=0; YES=0
  for a in "$@"; do case "$a" in
    --apply) APPLY=1;; --yes|-y) YES=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}freki artifacts${X}  ${DIM}· old CI workflow artifacts (age ≥ %sd)${X}\n\n" "$STALE_DAYS"

  local -a CAND=()  # repo \x1f artifact_id \x1f description
  local now; now=$(date +%s)
  local n=0 total_bytes=0 stale=0 stale_bytes=0

  while read -r d; do
    is_exempt "$d" && continue
    local rows; rows=$(gh api "repos/$OWNER/$d/actions/artifacts" --paginate --jq \
      '.artifacts[] | select(.expired==false) | [(.id|tostring),.name,(.size_in_bytes|tostring),.created_at] | @tsv' 2>/dev/null)
    [ -z "$rows" ] && continue
    local printed=0
    while IFS=$'\t' read -r id name bytes created; do
      [ -z "$id" ] && continue
      n=$((n+1)); total_bytes=$((total_bytes + bytes))
      local ts age; ts=$(date -d "$created" +%s 2>/dev/null); age=$(( (now - ${ts:-$now}) / 86400 ))
      [ "$printed" = 0 ] && { printf "  ${BD}%s${X}\n" "$d"; printed=1; }
      if [ "$age" -ge "$STALE_DAYS" ]; then
        printf "    ${DIM}∙${X} %s ${Y}(%s, %sd old)${X}\n" "$name" "$(human_size "$bytes")" "$age"
        CAND+=("$d"$'\x1f'"$id"$'\x1f'"$d artifact '$name' ($(human_size "$bytes"), ${age}d old)"); stale=$((stale+1)); stale_bytes=$((stale_bytes + bytes))
      else
        printf "    ${DIM}∙${X} %s ${DIM}(%s, %sd old)${X}\n" "$name" "$(human_size "$bytes")" "$age"
      fi
    done < <(printf '%s\n' "$rows")
  done < <(repos)

  REAP_ART_N=$n; REAP_ART_BYTES=$total_bytes; REAP_ART_STALE=$stale; REAP_ART_STALE_BYTES=$stale_bytes
  if [ "$n" -eq 0 ]; then printf "  ${G}✓ no artifacts anywhere${X}\n\n"; return 0; fi

  if [ "$APPLY" != 1 ]; then
    printf "\n  ${BD}%d artifact(s)${X} ${DIM}(%s)${X} ${DIM}·${X} ${Y}%d past %sd${X} ${DIM}(%s)${X} ${DIM}· 'freki artifacts --apply' deletes those${X}\n\n" \
      "$n" "$(human_size "$total_bytes")" "$stale" "$STALE_DAYS" "$(human_size "$stale_bytes")"
    return 0
  fi

  local m=${#CAND[@]}
  if [ "$m" -eq 0 ]; then printf "\n  ${G}✓ nothing past the threshold${X}\n\n"; return 0; fi

  printf "\n"
  if ! confirm "delete $m artifact(s) ($(human_size "$stale_bytes"))?"; then printf "  ${DIM}aborted — nothing deleted.${X}\n\n"; return 0; fi
  YES=1

  local deleted=0 failed=0 c
  for c in "${CAND[@]}"; do
    local repo id desc
    IFS=$'\x1f' read -r repo id desc <<< "$c"
    do_it "$repo" "artifact" "$desc" gh api -X DELETE "repos/$OWNER/$repo/actions/artifacts/$id" \
      && deleted=$((deleted+1)) || failed=$((failed+1))
  done
  printf "\n  ${BD}%d deleted${X}%s\n\n" "$deleted" "$([ "$failed" -gt 0 ] && printf "  ${DIM}·${X} ${R}%d failed${X}" "$failed")"
}

# ── releases (stale draft / pre-releases) ─────────────────────────────────
cmd_releases(){
  is_help "${1:-}" && { help_releases; return 0; }
  need_deps || return 1
  need_owner || return 1
  APPLY=0; YES=0
  for a in "$@"; do case "$a" in
    --apply) APPLY=1;; --yes|-y) YES=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}freki releases${X}  ${DIM}· stale draft / pre-releases (age ≥ %sd)${X}\n\n" "$STALE_DAYS"

  local -a CAND=()  # repo \x1f release_id \x1f description
  local now; now=$(date +%s)
  local n=0 stale=0

  while read -r d; do
    is_exempt "$d" && continue
    local rows; rows=$(gh api "repos/$OWNER/$d/releases" --paginate --jq \
      '.[] | select(.draft==true or .prerelease==true) | [(.id|tostring),.tag_name,(.draft|tostring),.created_at,(.published_at // "")] | @tsv' 2>/dev/null)
    [ -z "$rows" ] && continue
    local printed=0
    while IFS=$'\t' read -r id tag draft created published; do
      [ -z "$id" ] && continue
      n=$((n+1))
      local kind; [ "$draft" = "true" ] && kind="draft" || kind="prerelease"
      local refdate="${published:-$created}"; [ -z "$refdate" ] && refdate="$created"
      local ts age; ts=$(date -d "$refdate" +%s 2>/dev/null); age=$(( (now - ${ts:-$now}) / 86400 ))
      [ "$printed" = 0 ] && { printf "  ${BD}%s${X}\n" "$d"; printed=1; }
      if [ "$age" -ge "$STALE_DAYS" ]; then
        printf "    ${DIM}∙${X} %s ${Y}(%s, %sd old)${X}\n" "$tag" "$kind" "$age"
        CAND+=("$d"$'\x1f'"$id"$'\x1f'"$d release '$tag' ($kind, ${age}d old)"); stale=$((stale+1))
      else
        printf "    ${DIM}∙${X} %s ${DIM}(%s, %sd old)${X}\n" "$tag" "$kind" "$age"
      fi
    done < <(printf '%s\n' "$rows")
  done < <(repos)

  REAP_REL_N=$n; REAP_REL_STALE=$stale

  if [ "$n" -eq 0 ]; then printf "  ${G}✓ no draft or pre-releases anywhere${X}\n\n"; return 0; fi

  if [ "$APPLY" != 1 ]; then
    printf "\n  ${BD}%d draft/pre-release(s)${X} ${DIM}·${X} ${Y}%d past %sd${X} ${DIM}· 'freki releases --apply' deletes those${X}\n\n" "$n" "$stale" "$STALE_DAYS"
    return 0
  fi

  local m=${#CAND[@]}
  if [ "$m" -eq 0 ]; then printf "\n  ${G}✓ nothing past the threshold${X}\n\n"; return 0; fi

  printf "\n"
  if ! confirm "delete $m draft/pre-release(s)?"; then printf "  ${DIM}aborted — nothing deleted.${X}\n\n"; return 0; fi
  YES=1

  local deleted=0 failed=0 c
  for c in "${CAND[@]}"; do
    local repo id desc
    IFS=$'\x1f' read -r repo id desc <<< "$c"
    do_it "$repo" "release" "$desc" gh api -X DELETE "repos/$OWNER/$repo/releases/$id" \
      && deleted=$((deleted+1)) || failed=$((failed+1))
  done
  printf "\n  ${BD}%d deleted${X}%s\n\n" "$deleted" "$([ "$failed" -gt 0 ] && printf "  ${DIM}·${X} ${R}%d failed${X}" "$failed")"
}

# ── reap (the combined cruft summary) ─────────────────────────────────────
cmd_reap(){
  is_help "${1:-}" && { help_reap; return 0; }
  need_deps || return 1
  need_owner || return 1
  printf "\n  ${BD}freki reap${X}  ${DIM}· estate cruft summary · %s${X}\n\n" "$ROOT"

  REAP_BR_N=0; REAP_BR_REPOS=0; REAP_PR_N=0; REAP_PR_STALE=0
  REAP_ART_N=0; REAP_ART_BYTES=0; REAP_ART_STALE=0; REAP_ART_STALE_BYTES=0
  REAP_REL_N=0; REAP_REL_STALE=0

  cmd_branches  >/dev/null
  cmd_prs       >/dev/null
  cmd_artifacts >/dev/null
  cmd_releases  >/dev/null

  printf "  ${BD}branches${X}    %d reapable ${DIM}across %d repo(s)${X}\n" "$REAP_BR_N" "$REAP_BR_REPOS"
  printf "  ${BD}prs${X}         %d abandoned ${DIM}(of %d open)${X}\n" "$REAP_PR_STALE" "$REAP_PR_N"
  printf "  ${BD}artifacts${X}   %d reapable ${DIM}(%s, of %d total)${X}\n" "$REAP_ART_STALE" "$(human_size "$REAP_ART_STALE_BYTES")" "$REAP_ART_N"
  printf "  ${BD}releases${X}    %d reapable ${DIM}(of %d draft/pre)${X}\n" "$REAP_REL_STALE" "$REAP_REL_N"

  local total=$((REAP_BR_N + REAP_PR_STALE + REAP_ART_STALE + REAP_REL_STALE))
  if [ "$total" -eq 0 ]; then printf "\n  ${G}✓ nothing to reap anywhere${X}\n\n"; return 0; fi
  printf "\n  ${BD}%d thing(s) reapable${X} ${DIM}across the estate — apply per-command:${X}\n" "$total"
  printf "  ${DIM}freki branches|prs|artifacts|releases --apply${X}\n\n"
}

# ── per-command help ──────────────────────────────────────────────────────
help_branches(){
  printf "\n  ${BD}freki branches${X} [--apply] [--yes] [--force]\n\n"
  printf "  Merged and long-stale local + remote branches across the estate ${DIM}(extends huginn's\n"
  printf "  'branches --prune' to remote and estate-wide)${X}. Lists candidates; ${BD}--apply${X} deletes.\n"
  printf "  ${BD}Never${X} the default branch or the currently checked-out branch; ${BD}never${X} an\n"
  printf "  unmerged branch unless ${BD}--force${X} — and even then, confirms once for the whole batch\n"
  printf "  before deleting anything (skip the prompt with ${BD}--yes${X}). Excludes exempt repos\n"
  printf "  (\$HUGINN_FAMILY + exemptions.json). ${DIM}Stale threshold: \$FREKI_STALE_DAYS (default %s days).\n" "$STALE_DAYS"
  printf "  Network — fetches each repo's remote before checking merge status, and --apply on a\n"
  printf "  remote branch pushes a delete to origin.${X}\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --apply   delete merged branches (and stale-unmerged ones if --force is also set)\n"
  printf "    --force   also make stale, unmerged branches eligible for deletion\n"
  printf "    --yes     skip the confirmation prompt\n\n"
}
help_prs(){
  printf "\n  ${BD}freki prs${X} [--apply] [--yes]\n\n"
  printf "  Open pull requests across the estate with no activity in \$FREKI_PR_STALE_DAYS\n"
  printf "  ${DIM}(default: %s days)${X}. Lists every open PR, marking the abandoned ones; ${BD}--apply${X}\n" "$PR_STALE_DAYS"
  printf "  closes those with a courteous comment. Never touches PRs with recent activity.\n"
  printf "  Excludes exempt repos (\$HUGINN_FAMILY + exemptions.json). ${DIM}Network — one search query\n"
  printf "  plus one 'gh pr close' per abandoned PR on --apply.${X}\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --apply   close the abandoned PRs (confirms once for the batch)\n"
  printf "    --yes     skip the confirmation prompt\n\n"
}
help_artifacts(){
  printf "\n  ${BD}freki artifacts${X} [--apply] [--yes]\n\n"
  printf "  Old GitHub Actions workflow artifacts ${DIM}(they silently consume the storage quota)${X},\n"
  printf "  age ≥ \$FREKI_STALE_DAYS ${DIM}(default: %s days)${X}, excluding already-expired ones (GitHub\n" "$STALE_DAYS"
  printf "  reclaims those itself). Lists by age/size; ${BD}--apply${X} deletes those past the threshold.\n"
  printf "  Excludes exempt repos (\$HUGINN_FAMILY + exemptions.json). ${DIM}Network — one API call per\n"
  printf "  repo to list, one per artifact deleted on --apply.${X}\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --apply   delete the artifacts past the threshold (confirms once for the batch)\n"
  printf "    --yes     skip the confirmation prompt\n\n"
}
help_releases(){
  printf "\n  ${BD}freki releases${X} [--apply] [--yes]\n\n"
  printf "  Stale draft releases and old pre-releases, age ≥ \$FREKI_STALE_DAYS ${DIM}(default: %s\n" "$STALE_DAYS"
  printf "  days)${X}. Lists them; ${BD}--apply${X} deletes the release ${DIM}(the underlying git tag, if any,\n"
  printf "  is left alone)${X}. ${BD}Never${X} a published (non-draft, non-prerelease) release or its tag.\n"
  printf "  Excludes exempt repos (\$HUGINN_FAMILY + exemptions.json).\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --apply   delete the drafts/pre-releases past the threshold (confirms once for the batch)\n"
  printf "    --yes     skip the confirmation prompt\n\n"
}
help_reap(){
  printf "\n  ${BD}freki reap${X}\n\n"
  printf "  The combined \"here's all the cruft\" summary across branches/prs/artifacts/releases,\n"
  printf "  with an estate headline. ${BD}Dry-run only${X} — reap never deletes anything itself;\n"
  printf "  apply per-command (${BD}freki branches|prs|artifacts|releases --apply${X}).\n\n"
  printf "  ${DIM}Network — runs the full scan for all four commands, so it's the slowest one.${X}\n\n"
}

# ── help ──────────────────────────────────────────────────────────────────
cmd_help(){
  printf "\n  ${BD}freki${X} ${DIM}— the estate's reaper · %s${X}\n\n" "$ROOT"
  printf "  ${DIM}reap${X}\n"
  printf "    ${BD}branches${X} [--apply]    merged/stale branches, estate-wide\n"
  printf "    ${BD}prs${X} [--apply]         abandoned open PRs\n"
  printf "    ${BD}artifacts${X} [--apply]   old CI workflow artifacts\n"
  printf "    ${BD}releases${X} [--apply]    stale draft / pre-releases\n"
  printf "    ${BD}reap${X}                  the combined cruft summary (dry-run only)\n"
  printf "  ${DIM}reference${X}\n"
  printf "    ${BD}help${X}                  this menu\n\n"
  printf "  ${DIM}dry-run by default — every command needs${X} ${BD}--apply${X} ${DIM}to actually delete anything.${X}\n"
  printf "  ${DIM}run${X} ${BD}freki <command> help${X} ${DIM}for details & options on any command.${X}\n\n"
}

case "${1:-help}" in
  branches|br)   shift; cmd_branches "$@";;
  prs)           shift; cmd_prs "$@";;
  artifacts|art) shift; cmd_artifacts "$@";;
  releases|rel)  shift; cmd_releases "$@";;
  reap)          shift; cmd_reap "$@";;
  help|-h|--help) cmd_help;;
  *) printf "${R}unknown command: %s${X}\n" "$1"; cmd_help; exit 1;;
esac
